<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/background_yellow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_yellow"
        tools:context=".presentation.main.home.MainActivity">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_icon"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:src="@mipmap/ic_launcher"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/RoundedImage" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="15dp"
                android:text="@string/main_title"
                android:textColor="@color/dark_gray"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/tv_subtitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/iv_icon"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/main_subtitle"
                android:textColor="@color/text_secondary_gray"
                android:textSize="18sp"
                android:layout_marginBottom="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/tv_title"
                app:layout_constraintStart_toStartOf="@id/tv_title"
                app:layout_constraintTop_toBottomOf="@id/tv_title" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_setting"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/ic_setting"
                android:layout_marginEnd="20dp"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintHeight_percent="0.25"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/iv_icon"
                app:layout_constraintBottom_toBottomOf="@id/iv_icon"/>

            <View
                android:id="@+id/v_line"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/header_line_orange"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_question"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="30dp"
            android:layout_marginEnd="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cl_header"
            app:strokeColor="@color/primary_red"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/iv_question_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ic_message_red_24"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="15dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tv_question_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="15dp"
                    android:text="@string/main_question_title"
                    android:textColor="@color/primary_red"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/iv_question_icon"
                    app:layout_constraintBottom_toBottomOf="@id/iv_question_icon"
                    app:layout_constraintStart_toEndOf="@id/iv_question_icon"/>

                <TextView
                    android:id="@+id/tv_question_content"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/main_question_mock"
                    android:textColor="@color/text_secondary_gray"
                    android:layout_marginStart="15dp"
                    android:layout_marginTop="15dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_question_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="@id/tv_question_title"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_answer"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/btn_primary_red"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="15dp"
                    android:layout_marginEnd="5dp"
                    android:text="@string/main_question_answer"
                    android:textColor="@color/white"
                    app:layout_constraintWidth_percent="0.6"
                    app:layout_constraintHeight_percent="0.25"
                    app:layout_constraintTop_toBottomOf="@id/tv_question_content"
                    app:layout_constraintStart_toStartOf="@id/iv_question_icon"
                    app:layout_constraintEnd_toStartOf="@id/btn_later"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_later"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/btn_later_unpressed"
                    android:layout_marginStart="5dp"
                    android:text="@string/main_question_later"
                    android:textColor="@color/primary_red"
                    app:layout_constraintTop_toTopOf="@id/btn_answer"
                    app:layout_constraintStart_toEndOf="@id/btn_answer"
                    app:layout_constraintEnd_toEndOf="@id/tv_question_title"
                    app:layout_constraintBottom_toBottomOf="@id/btn_answer"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_trip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cv_question"
            app:strokeColor="@color/hover_orange"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_trip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/iv_trip_image"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:background="@drawable/image_trip"
                    app:layout_constraintDimensionRatio="1:0.5"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <!--<TextView
                    android:id="@+id/tv_trip_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:layout_marginStart="15dp"
                    android:layout_marginEnd="15dp"
                    android:text="@string/main_trip_title_mock"
                    android:textColor="@color/dark_gray"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iv_trip_image"
                    app:layout_constraintStart_toStartOf="parent"/>-->

                <ImageView
                    android:id="@+id/iv_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ic_location_gray_24"
                    android:layout_marginStart="11dp"
                    android:layout_marginTop="15dp"
                    app:layout_constraintTop_toBottomOf="@id/iv_trip_image"
                    app:layout_constraintStart_toStartOf="@id/iv_trip_image"/>

                <TextView
                    android:id="@+id/tv_trip_current_location_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary_gray"
                    android:textSize="15sp"
                    app:layout_constraintStart_toEndOf="@id/iv_location"
                    app:layout_constraintTop_toTopOf="@id/iv_location"
                    app:layout_constraintBottom_toBottomOf="@id/iv_location"/>

                <TextView
                    android:id="@+id/tv_trip_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:layout_marginStart="15dp"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary_gray"
                    app:layout_constraintTop_toBottomOf="@id/iv_location"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tv_trip_day"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary_gray"
                    app:layout_constraintBottom_toBottomOf="@id/tv_trip_date"
                    app:layout_constraintStart_toEndOf="@id/tv_trip_date"/>

                <!--<ImageView
                    android:id="@+id/iv_trip_photo"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/ic_photo_gray"
                    android:layout_marginTop="25dp"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintWidth_percent="0.1"
                    app:layout_constraintTop_toBottomOf="@id/tv_trip_date"
                    app:layout_constraintStart_toStartOf="@id/tv_trip_title"
                    app:layout_constraintEnd_toStartOf="@id/iv_trip_answer"/>

                <ImageView
                    android:id="@+id/iv_trip_answer"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/ic_answer_gray"
