                    app:layout_constraintWidth_percent="0.1"
                    app:layout_constraintTop_toTopOf="@id/iv_trip_photo"
                    app:layout_constraintStart_toEndOf="@id/iv_trip_photo"
                    app:layout_constraintEnd_toStartOf="@id/iv_trip_complete"/>

                <ImageView
                    android:id="@+id/iv_trip_complete"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/ic_complete_gray"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintWidth_percent="0.1"
                    app:layout_constraintTop_toTopOf="@id/iv_trip_photo"
                    app:layout_constraintStart_toEndOf="@id/iv_trip_answer"
                    app:layout_constraintEnd_toEndOf="@id/tv_trip_title"/>

                <TextView
                    android:id="@+id/tv_trip_photo_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="2"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary_gray"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/iv_trip_photo"
                    app:layout_constraintStart_toStartOf="@id/iv_trip_photo"
                    app:layout_constraintEnd_toEndOf="@id/iv_trip_photo"/>

                <TextView
                    android:id="@+id/tv_trip_answer_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="2"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary_gray"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/iv_trip_answer"
                    app:layout_constraintStart_toStartOf="@id/iv_trip_answer"
                    app:layout_constraintEnd_toEndOf="@id/iv_trip_answer"/>

                <TextView
                    android:id="@+id/tv_trip_complete_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="2/4"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary_gray"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/iv_trip_complete"
                    app:layout_constraintStart_toStartOf="@id/iv_trip_complete"
                    app:layout_constraintEnd_toEndOf="@id/iv_trip_complete"/>-->

                <TextView
                    android:id="@+id/tv_trip_progress_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="25dp"
                    android:text="@string/main_trip_progress"
                    android:textSize="17sp"
                    app:layout_constraintTop_toBottomOf="@id/tv_trip_date"
                    app:layout_constraintStart_toStartOf="@id/iv_location"/>

                <TextView
                    android:id="@+id/tv_trip_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary_gray"
                    android:layout_marginEnd="15dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_trip_progress_title"
                    app:layout_constraintBottom_toBottomOf="@id/tv_trip_progress_title"/>

                <ProgressBar
                    android:id="@+id/pb_trip"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="12dp"
                    android:progressDrawable="@drawable/progressbar_travel"
                    android:progress="0"
                    android:max="100"
                    android:indeterminate="false"
                    android:layout_marginTop="10dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_trip_progress_title"
                    app:layout_constraintStart_toStartOf="@id/tv_trip_progress_title"
                    app:layout_constraintEnd_toEndOf="@id/tv_trip_progress"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_trip_detail"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
