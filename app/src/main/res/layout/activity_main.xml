                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="15dp"
                    android:layout_marginEnd="15dp"
                    android:text="@string/main_trip_detail"
                    android:textColor="@color/white"
                    app:layout_constraintHeight_percent="0.08"
                    app:layout_constraintTop_toBottomOf="@id/pb_trip"
                    app:layout_constraintStart_toStartOf="@id/tv_trip_date"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

               <!-- <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_upload"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/btn_later_unpressed"
                    android:layout_marginStart="5dp"
                    android:text="@string/main_trip_upload"
                    android:textColor="@color/primary_red"
                    app:layout_constraintTop_toTopOf="@id/btn_trip_detail"
                    app:layout_constraintStart_toEndOf="@id/btn_trip_detail"
