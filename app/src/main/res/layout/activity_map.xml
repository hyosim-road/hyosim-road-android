<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/text_secondary_gray">

    <!-- 지도 Fragment or View -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fcv_map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:name="com.hyosimroad.hamkkae.presentation.main.map.MapFragment"/>

    <!-- 상단 툴바 -->
    <!--<include layout="@layout/toolbar_map" />-->

    <!-- Bottom Sheet -->
    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet_white"
        android:padding="16dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <!-- 드래그 핸들 -->
        <View
            android:id="@+id/handle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="@drawable/bg_handle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 장소명 -->
        <TextView
            android:id="@+id/tv_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/dark_gray"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="5dp"
            app:layout_constraintTop_toBottomOf="@id/handle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/iv_image"
            app:layout_constraintHorizontal_chainStyle="spread_inside" />

        <!-- 거리 -->
        <TextView
            android:id="@+id/tv_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/text_secondary_gray"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tv_name"
            app:layout_constraintStart_toStartOf="@id/tv_name"/>

        <!-- 썸네일 이미지 -->
        <ImageView
            android:id="@+id/iv_image"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginStart="8dp"
            android:scaleType="centerCrop"
            android:background="#DDD"
            android:src="@drawable/image_trip"
            app:layout_constraintTop_toTopOf="@id/tv_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/iv_clock"/>

        <ImageView
            android:id="@+id/iv_pin"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="9dp"
            android:background="@drawable/ic_pin_gray_24"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.06"
            app:layout_constraintTop_toBottomOf="@id/tv_distance"
            app:layout_constraintStart_toStartOf="@id/tv_distance"/>

        <!-- 카테고리 -->
        <TextView
            android:id="@+id/tv_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textSize="14sp"
            android:textColor="@color/text_secondary_gray"
            android:background="@drawable/bg_type_white_stroke"
            android:layout_marginStart="3dp"
            app:layout_constraintBottom_toBottomOf="@id/iv_pin"
            app:layout_constraintStart_toEndOf="@id/iv_pin" />

        <ImageView
            android:id="@+id/iv_clock"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="6dp"
            android:src="@drawable/ic_clock_orange_32"
            app:tint="@color/text_secondary_gray"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.06"
            app:layout_constraintTop_toBottomOf="@id/iv_pin"
            app:layout_constraintStart_toStartOf="@id/tv_distance"/>

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:textSize="14sp"
            android:textColor="@color/text_secondary_gray"
            app:layout_constraintBottom_toBottomOf="@id/iv_clock"
            app:layout_constraintStart_toEndOf="@id/iv_clock" />


        <TextView
            android:id="@+id/tv_amenity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/info_amenities"
            android:textColor="@color/text_secondary_gray"
            app:layout_constraintTop_toBottomOf="@id/iv_clock"
            app:layout_constraintStart_toStartOf="@id/iv_clock"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_amenities"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:layout_constraintTop_toBottomOf="@id/tv_amenity"
            app:layout_constraintStart_toStartOf="@id/tv_amenity"
            app:layout_constraintEnd_toEndOf="parent"/>

        <LinearLayout
            android:id="@+id/btn_navigate"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_primary_unpressed"
            android:layout_marginBottom="15dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/rv_amenities"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/iv_album"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:rotation="45"
                android:src="@drawable/ic_navi_gray_24"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/tv_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/map_navigate"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
