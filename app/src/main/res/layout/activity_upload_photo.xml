<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_yellow">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_back"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/ic_back_black_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.08" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:text="@string/upload_photo_title"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/tv_date"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="@string/upload_photo_subtitle"
            android:textColor="@color/text_secondary_gray"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="@id/tv_title"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />

        <View
            android:id="@+id/v_line"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/header_line_orange"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_current"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:background="@color/white"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_header">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_current"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/iv_pin_bg"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="15dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_schedule_gray"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.1" />

            <ImageView
                android:id="@+id/iv_pin"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/ic_pin_gray_24"
                app:layout_constraintBottom_toBottomOf="@id/iv_pin_bg"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="@id/iv_pin_bg"
                app:layout_constraintStart_toStartOf="@id/iv_pin_bg"
                app:layout_constraintTop_toTopOf="@id/iv_pin_bg"
                app:layout_constraintWidth_percent="0.06" />

            <TextView
                android:id="@+id/tv_current"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/main_trip_current_location"
                android:textColor="@color/text_secondary_gray"
                android:textSize="17sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/tv_time"
                app:layout_constraintStart_toEndOf="@id/iv_pin_bg"
                app:layout_constraintTop_toTopOf="@id/iv_pin_bg" />

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/main_time"
                android:textColor="@color/text_secondary_gray"
                android:textSize="15sp"
                app:layout_constraintBottom_toBottomOf="@id/iv_pin_bg"
                app:layout_constraintStart_toStartOf="@id/tv_current"
                app:layout_constraintTop_toBottomOf="@id/tv_current" />

            <TextView
                android:id="@+id/tv_in_process"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="15dp"
                android:background="@drawable/bg_current_orange"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="@string/state_in_progress"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/iv_pin_bg"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/iv_pin_bg" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_upload"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_white_stroke"
        app:layout_constraintEnd_toEndOf="@id/cv_current"
        app:layout_constraintStart_toStartOf="@id/cv_current"
        app:layout_constraintTop_toBottomOf="@id/cv_current">

        <TextView
            android:id="@+id/tv_upload"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginTop="10dp"
            android:text="@string/upload_photo_upload"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_photo_upload"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="15dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_upload_stroke"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tv_upload"
            app:layout_constraintTop_toBottomOf="@id/tv_upload">

            <ImageView
                android:id="@+id/iv_camera"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/ic_camera_gray_24"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.15" />

            <TextView
                android:id="@+id/tv_upload_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="10dp"
                android:gravity="center"
                android:text="@string/upload_photo_upload_title"
                android:textColor="@color/text_secondary_gray"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_camera" />

            <TextView
                android:id="@+id/tv_upload_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:gravity="center"
                android:text="@string/upload_photo_upload_subtitle"
                android:textColor="@color/text_secondary_gray"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="@id/tv_upload_title"
                app:layout_constraintStart_toStartOf="@id/tv_upload_title"
                app:layout_constraintTop_toBottomOf="@id/tv_upload_title" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_select_photo"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/upload_photo_upload_photo"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                app:backgroundTint="@color/primary_red"
                app:cornerRadius="5dp"
                app:icon="@drawable/ic_upload_white_24"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@color/white"
                app:rippleColor="#33FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/tv_upload_subtitle"
                app:layout_constraintStart_toStartOf="@id/tv_upload_subtitle"
                app:layout_constraintEnd_toEndOf="@id/tv_upload_subtitle"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
        
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_photo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="15dp"
            android:layout_marginTop="15dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tv_upload"
            app:layout_constraintStart_toStartOf="@id/tv_upload"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/iv_photo"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintDimensionRatio="1:0.4"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reselect"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/upload_photo_upload_again"
                android:textAllCaps="false"
                android:textColor="@color/text_secondary_gray"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="15dp"
                android:layout_marginEnd="5dp"
                app:backgroundTint="@color/white"
                app:strokeColor="@color/state_complete_gray"
                app:strokeWidth="1dp"
                app:cornerRadius="5dp"
                app:icon="@drawable/ic_upload_white_24"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@color/text_secondary_gray"
                app:rippleColor="#33FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/iv_photo"
                app:layout_constraintStart_toStartOf="@id/iv_photo"
                app:layout_constraintEnd_toStartOf="@id/btn_complete"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_complete"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="5dp"
                android:text="@string/upload_photo_upload_complete"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="@color/primary_red"
                app:cornerRadius="5dp"
                app:rippleColor="#33FFFFFF"
                app:layout_constraintTop_toTopOf="@id/btn_reselect"
                app:layout_constraintStart_toEndOf="@id/btn_reselect"
                app:layout_constraintEnd_toEndOf="@id/iv_photo"
                app:layout_constraintBottom_toBottomOf="@id/btn_reselect"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_tip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_white_stroke"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/cl_upload"
        app:layout_constraintStart_toStartOf="@id/cl_upload"
        app:layout_constraintEnd_toEndOf="@id/cl_upload">

        <TextView
            android:id="@+id/tv_tip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="15dp"
            android:text="@string/upload_photo_tip"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary_gray"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_tip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="15dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/tv_tip"
            app:layout_constraintStart_toStartOf="@id/tv_tip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>