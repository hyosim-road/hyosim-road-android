<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/photo_bg_blue">

<ImageView
    android:id="@+id/iv_complete"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:layout_marginTop="64dp"
    android:background="@drawable/ic_complete_blue_120"
    app:layout_constraintDimensionRatio="1:1"
    app:layout_constraintWidth_percent="0.25"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_complete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/upload_photo_complete"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/iv_complete"
        app:layout_constraintStart_toStartOf="@id/iv_complete"
        app:layout_constraintEnd_toEndOf="@id/iv_complete"/>

    <TextView
        android:id="@+id/tv_complete_detail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/upload_photo_place"
        android:textSize="17sp"
        android:textColor="@color/text_secondary_gray"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="1dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tv_complete"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_complete_place"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="5dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/secondary_blue"
        app:cardBackgroundColor="@color/upload_photo_complete_bg_blue"
        app:layout_constraintTop_toBottomOf="@id/tv_complete_detail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_complete_place"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/iv_complete_icon"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/ic_complete_blue_60"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="20dp"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintWidth_percent="0.1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/tv_place"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:text="@string/main_trip_location_mock"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/upload_photo_complete_text_blue"
                app:layout_constraintTop_toTopOf="@id/iv_complete_icon"
                app:layout_constraintStart_toEndOf="@id/iv_complete_icon"
                app:layout_constraintBottom_toTopOf="@id/iv_time"/>

            <TextView
                android:id="@+id/tv_keyword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/keyword_history"
                android:textColor="@color/secondary_blue"
                android:textStyle="bold"
                android:background="@drawable/bg_text_blue"
                android:layout_marginStart="10dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                app:layout_constraintTop_toTopOf="@id/tv_place"
                app:layout_constraintBottom_toBottomOf="@id/tv_place"
                app:layout_constraintStart_toEndOf="@id/tv_place"/>

            <TextView
                android:id="@+id/tv_current"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/main_current"
                android:textColor="@color/white"
                android:background="@drawable/bg_current_orange"
                android:layout_marginStart="6dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="@id/tv_place"
                app:layout_constraintBottom_toBottomOf="@id/tv_place"
                app:layout_constraintStart_toEndOf="@id/tv_keyword"/>

            <TextView
                android:id="@+id/tv_description"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="15dp"
                android:gravity="start"
                android:textColor="@color/text_secondary_gray"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tv_place"
                app:layout_constraintStart_toStartOf="@id/tv_place"
                app:layout_constraintEnd_toEndOf="parent"/>

            <ImageView
                android:id="@+id/iv_time"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:src="@drawable/ic_time_gray_24"
                android:layout_marginTop="5dp"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintWidth_percent="0.04"
                app:layout_constraintTop_toBottomOf="@id/tv_place"
                app:layout_constraintStart_toStartOf="@id/tv_place"
                app:layout_constraintBottom_toBottomOf="@id/iv_complete_icon"
                app:tint="@color/secondary_blue" />

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/secondary_blue"
                android:textSize="13sp"
                android:layout_marginStart="3dp"
                app:layout_constraintTop_toTopOf="@id/iv_time"
                app:layout_constraintBottom_toBottomOf="@id/iv_time"
                app:layout_constraintStart_toEndOf="@id/iv_time"/>

            <TextView
                android:id="@+id/tv_state_complete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:text="@string/state_complete"
                android:textSize="13sp"
                android:textColor="@color/secondary_blue"
                android:background="@drawable/bg_state_blue"
                android:paddingStart="15dp"
                android:paddingEnd="15dp"
                app:layout_constraintTop_toTopOf="@id/iv_complete_icon"
                app:layout_constraintBottom_toBottomOf="@id/iv_complete_icon"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_upload_photo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="5dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/state_complete_gray"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/cv_complete_place"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_upload_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_upload_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upload_photo_complete_photo"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary_gray"
                android:layout_marginTop="15dp"
                android:layout_marginStart="15dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <ImageView
                android:id="@+id/iv_photo"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="15dp"
                app:layout_constraintDimensionRatio="1:0.5"
                app:layout_constraintTop_toBottomOf="@id/tv_upload_photo"
                app:layout_constraintStart_toStartOf="@id/tv_upload_photo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>



    <LinearLayout
        android:id="@+id/btn_home"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/btn_primary_unpressed"
        android:layout_marginBottom="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="@id/btn_share"
        app:layout_constraintEnd_toEndOf="@id/btn_share"
        app:layout_constraintBottom_toTopOf="@id/btn_share">

        <ImageView
            android:id="@+id/iv_next"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:rotation="180"
            android:src="@drawable/ic_back_black_24"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/tv_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/upload_photo_complete_home"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:includeFontPadding="false" />
    </LinearLayout>


    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_share"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:text="@string/upload_photo_complete_share"
        android:textAllCaps="false"
        android:textColor="@color/text_secondary_gray"
        android:textStyle="bold"
        android:textSize="15sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:paddingVertical="0dp"
        app:cornerRadius="5dp"
        app:strokeColor="@color/state_complete_gray"
        app:strokeWidth="1dp"
        app:backgroundTint="@color/white"
        app:icon="@drawable/ic_share_gray_24"
        app:iconTint="@color/text_secondary_gray"
        app:iconGravity="textStart"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>