<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.kakao.vectormap.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="15dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_attraction"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minHeight="0dp"
            android:layout_margin="3dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_filter_attraction_selector"
            android:text="여행지"
            android:textColor="@color/primary_orange"
            android:includeFontPadding="false"
            android:gravity="center"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_pin_gray_24"
            app:iconSize="20dp"
            app:iconTint="@color/primary_orange" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_lodging"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minHeight="0dp"
            android:layout_margin="3dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_filter_lodging_selector"
            android:backgroundTint="@null"
            android:text="숙소"
            android:textColor="@color/secondary_blue"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_lodging_white"
            app:iconSize="20dp"
            app:iconTint="@color/secondary_blue" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_restaurant"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_margin="3dp"
            android:background="@drawable/bg_filter_restaurant_selector"
            android:backgroundTint="@null"
            android:text="식당"
            android:textColor="@color/text_filter_restaurant"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_restaurant_white"
            app:iconSize="20dp"
            app:iconTint="@color/text_filter_restaurant" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>