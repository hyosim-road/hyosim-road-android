<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_tip_with_parent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_detail_white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_tip_with_parent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/tip_title"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="15dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/iv_people"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_people_gray_24"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tv_tip_with_parent"
            app:layout_constraintStart_toStartOf="@id/tv_tip_with_parent"/>

        <TextView
            android:id="@+id/tv_caution"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="10dp"
            android:text="@string/tip_caution"
            android:textColor="@color/text_secondary_gray"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="@id/iv_people"
            app:layout_constraintBottom_toBottomOf="@id/iv_people"
            app:layout_constraintStart_toEndOf="@id/iv_people"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_caution"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/iv_people"
            app:layout_constraintStart_toStartOf="@id/iv_people"
            app:layout_constraintEnd_toEndOf="@id/tv_caution"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:listitem="@layout/item_text"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_best_visit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:background="@drawable/bg_detail_white"
        app:layout_constraintTop_toBottomOf="@id/cl_tip_with_parent"
        app:layout_constraintStart_toStartOf="@id/cl_tip_with_parent"
        app:layout_constraintEnd_toEndOf="@id/cl_tip_with_parent">

        <TextView
            android:id="@+id/tv_best_visit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/tip_best_visit"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="15dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_best_visit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/tv_best_visit"
            app:layout_constraintStart_toStartOf="@id/tv_best_visit"
            app:layout_constraintEnd_toEndOf="@id/tv_best_visit"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_checklist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:background="@drawable/bg_detail_white"
        app:layout_constraintTop_toBottomOf="@id/cl_best_visit"
        app:layout_constraintStart_toStartOf="@id/cl_tip_with_parent"
        app:layout_constraintEnd_toEndOf="@id/cl_tip_with_parent">

        <TextView
            android:id="@+id/tv_checklist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/tip_checklist"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="15dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_checklist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="2"
            app:layout_constraintTop_toBottomOf="@id/tv_checklist"
            app:layout_constraintStart_toStartOf="@id/tv_checklist"
            app:layout_constraintEnd_toEndOf="@id/tv_checklist"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>