<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_header"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_yellow"
    android:paddingBottom="40dp">

    <TextView
        android:id="@+id/tv_trip_progress_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:layout_marginStart="20dp"
        android:text="@string/select_trip_style_progress_title"
        android:textSize="17sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tv_trip_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:text="@string/select_trip_style_progress"
        android:textSize="15sp"
        android:textColor="@color/text_secondary_gray"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_trip_progress_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_trip_progress_title"/>

    <ProgressBar
        android:id="@+id/pb_trip"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="0dp"
        android:layout_height="12dp"
        android:progressDrawable="@drawable/progressbar_travel"
        android:max="100"
        android:indeterminate="false"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/tv_trip_progress_title"
        app:layout_constraintStart_toStartOf="@id/tv_trip_progress_title"
        app:layout_constraintEnd_toEndOf="@id/tv_trip_progress"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_trip_style"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="10dp"
        android:clipToPadding="false"
        android:nestedScrollingEnabled="false"
        android:overScrollMode="never"
        android:paddingBottom="8dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pb_trip"
        tools:listitem="@layout/item_trip_style" />

