<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_pink">

        <TextView
            android:id="@+id/tv_trip_progress_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="25dp"
            android:text="@string/trip_complete_progress_title"
            android:textSize="17sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_trip_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:text="@string/trip_complete_progress"
            android:textColor="@color/text_secondary_gray"
            android:textSize="15sp"
            app:layout_constraintBottom_toBottomOf="@id/tv_trip_progress_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_trip_progress_title" />

        <ProgressBar
            android:id="@+id/pb_trip"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="12dp"
            android:layout_marginTop="10dp"
            android:indeterminate="false"
            android:max="100"
            android:progressDrawable="@drawable/progressbar_travel"
            app:layout_constraintEnd_toEndOf="@id/tv_trip_progress"
            app:layout_constraintStart_toStartOf="@id/tv_trip_progress_title"
            app:layout_constraintTop_toBottomOf="@id/tv_trip_progress_title" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_trip_summation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_red"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pb_trip">

            <ImageView
                android:id="@+id/iv_pin_icon"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="30dp"
                android:background="@drawable/ic_pin_red"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.2" />

            <TextView
                android:id="@+id/tv_trip_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:gravity="center"
                android:text="@string/main_trip_title_mock"
                android:textColor="@color/dark_gray"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_pin_icon" />

            <TextView
                android:id="@+id/tv_trip_complete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:gravity="center"
                android:text="@string/trip_summation_complete"
                android:textColor="@color/text_secondary_gray"
                app:layout_constraintEnd_toEndOf="@id/tv_trip_name"
                app:layout_constraintStart_toStartOf="@id/tv_trip_name"
                app:layout_constraintTop_toBottomOf="@id/tv_trip_name" />

            <ImageView
                android:id="@+id/iv_bg_during_white"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="-20dp"
                android:background="@color/white"
                app:layout_constraintBottom_toBottomOf="@id/tv_during"
                app:layout_constraintEnd_toStartOf="@id/iv_bg_personnel_white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_trip_complete" />

            <ImageView
                android:id='@+id/iv_calendar'
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/ic_calendar_red_24"
                app:layout_constraintEnd_toEndOf="@id/iv_bg_during_white"
                app:layout_constraintStart_toStartOf="@id/iv_bg_during_white"
                app:layout_constraintTop_toTopOf="@id/iv_bg_during_white" />

            <TextView
                android:id="@+id/tv_during_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/trip_summation_during"
                android:textColor="@color/text_secondary_gray"
                app:layout_constraintEnd_toEndOf="@id/iv_bg_during_white"
                app:layout_constraintStart_toStartOf="@id/iv_bg_during_white"
                app:layout_constraintTop_toBottomOf="@id/iv_calendar" />

            <TextView
                android:id="@+id/tv_during"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="20dp"
                android:gravity="center"
                android:text="2박 3일"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/iv_bg_during_white"
                app:layout_constraintStart_toStartOf="@id/iv_bg_during_white"
                app:layout_constraintTop_toBottomOf="@id/tv_during_title" />

            <ImageView
                android:id="@+id/iv_bg_personnel_white"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="-20dp"
                android:background="@color/white"
                app:layout_constraintBottom_toBottomOf="@id/tv_personnel"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/iv_bg_during_white"
                app:layout_constraintTop_toBottomOf="@id/tv_trip_complete" />

            <ImageView
                android:id='@+id/iv_personnel'
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/ic_people_red_24"
                app:layout_constraintEnd_toEndOf="@id/iv_bg_personnel_white"
                app:layout_constraintStart_toStartOf="@id/iv_bg_personnel_white"
                app:layout_constraintTop_toTopOf="@id/iv_bg_personnel_white" />

            <TextView
                android:id="@+id/tv_personnel_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/trip_summation_personnel"
                android:textColor="@color/text_secondary_gray"
                app:layout_constraintEnd_toEndOf="@id/iv_bg_personnel_white"
                app:layout_constraintStart_toStartOf="@id/iv_bg_personnel_white"
                app:layout_constraintTop_toBottomOf="@id/iv_personnel" />

            <TextView
                android:id="@+id/tv_personnel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="20dp"
                android:gravity="center"
                android:text="3명"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/iv_bg_personnel_white"
                app:layout_constraintStart_toStartOf="@id/iv_bg_personnel_white"
                app:layout_constraintTop_toBottomOf="@id/tv_personnel_title" />

            <ImageView
                android:id="@+id/iv_bg_date_white"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="-10dp"
                android:background="@color/white"
                app:layout_constraintBottom_toBottomOf="@id/tv_date"
                app:layout_constraintEnd_toEndOf="@id/iv_bg_personnel_white"
                app:layout_constraintStart_toStartOf="@id/iv_bg_during_white"
                app:layout_constraintTop_toBottomOf="@id/iv_bg_during_white" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="30dp"
                android:gravity="center"
                android:text="2025.07.21 ~ 2025.07.23"
                android:textColor="@color/text_secondary_gray"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/iv_bg_date_white"
                app:layout_constraintStart_toStartOf="@id/iv_bg_date_white"
                app:layout_constraintTop_toTopOf="@id/iv_bg_date_white" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/cd_preview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cl_trip_summation">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_preview_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="15dp"
                    android:layout_marginTop="20dp"
                    android:text="@string/trip_preview_title"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_preview"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="15dp"
                    android:layout_marginBottom="10dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/tv_preview_title"
                    app:layout_constraintTop_toBottomOf="@id/tv_preview_title"
                    tools:listitem="@layout/item_trip_schedule" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_tip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_complete_tip_yellow"
            app:layout_constraintEnd_toEndOf="@id/cd_preview"
            app:layout_constraintStart_toStartOf="@id/cd_preview"
            app:layout_constraintTop_toBottomOf="@id/cd_preview">

            <ImageView
                android:id='@+id/iv_clock'
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:background="@drawable/ic_clock_orange_32"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_tip_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/trip_complete_tip_title"
                android:textColor="@color/dark_gray"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_clock" />

            <TextView
                android:id="@+id/tv_tip_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="20dp"
                android:gravity="center"
                android:text="@string/trip_complete_tip_subtitle"
                android:textColor="@color/text_secondary_gray"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_tip_title" />

            <ImageView
                android:id="@+id/iv_tip_bg"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_tip_yellow"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/tv_tip_subtitle"
                app:layout_constraintStart_toStartOf="@id/tv_tip_subtitle"
                app:layout_constraintTop_toBottomOf="@id/tv_tip_subtitle" />

            <ImageView
                android:id="@+id/iv_tip_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/ic_tip_yellow_20"
                app:layout_constraintBottom_toBottomOf="@id/tv_tip"
                app:layout_constraintStart_toStartOf="@id/iv_tip_bg"
                app:layout_constraintTop_toTopOf="@id/tv_tip" />

            <TextView
                android:id="@+id/tv_tip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="10dp"
                android:text="@string/trip_complete_tip"
                android:textColor="@color/primary_orange"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@id/iv_tip_bg"
                app:layout_constraintEnd_toEndOf="@id/iv_tip_bg"
                app:layout_constraintStart_toEndOf="@id/iv_tip_icon"
                app:layout_constraintTop_toTopOf="@id/iv_tip_bg" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_start"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/btn_primary"
            android:text="@string/trip_complete_trip_start"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:layout_constraintDimensionRatio="1:0.13"
            app:layout_constraintEnd_toEndOf="@id/cl_tip"
            app:layout_constraintStart_toStartOf="@id/cl_tip"
            app:layout_constraintTop_toBottomOf="@id/cl_tip" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_start">

            <TextView
                android:id="@+id/tv_enjoy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="즐거운 여행 되세요!"
                android:textColor="@color/text_secondary_gray"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/iv_enjoy_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_enjoy_24" />
        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>