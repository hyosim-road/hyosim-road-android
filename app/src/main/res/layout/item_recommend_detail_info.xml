<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="12dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="10dp"
        app:cardElevation="1.7dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

           <!-- <TextView
                android:id="@+id/tv_type"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="10dp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:background="@drawable/bg_current_orange"
                android:elevation="3dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>-->

            <ImageView
                android:id="@+id/iv_image"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:scaleType="centerCrop"
                app:layout_constraintDimensionRatio="1:0.4"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/dark_gray"
                android:breakStrategy="simple"
                app:layout_constraintTop_toBottomOf="@id/iv_image"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <ImageView
                android:id="@+id/iv_wallet"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="6dp"
                android:src="@drawable/ic_wallet_24_white"
                app:tint="@color/text_secondary_gray"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintWidth_percent="0.052"
                app:layout_constraintTop_toBottomOf="@id/tv_name"
                app:layout_constraintStart_toStartOf="@id/tv_name"/>

            <TextView
                android:id="@+id/tv_cost"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:textColor="@color/text_secondary_gray"
                android:textSize="15.5sp"
                app:layout_constraintTop_toTopOf="@id/iv_wallet"
                app:layout_constraintBottom_toBottomOf="@id/iv_wallet"
                app:layout_constraintStart_toEndOf="@id/iv_wallet"/>

            <ImageView
                android:id="@+id/iv_pin"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="6dp"
                android:src="@drawable/ic_pin_gray_24"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintWidth_percent="0.052"
                app:layout_constraintTop_toBottomOf="@id/iv_wallet"
                app:layout_constraintStart_toStartOf="@id/tv_name"/>

            <TextView
                android:id="@+id/tv_location"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:layout_marginEnd="15dp"
                android:layout_marginTop="1dp"
                android:textColor="@color/text_secondary_gray"
                android:textSize="15.5sp"
                android:breakStrategy="simple"
                app:layout_constraintTop_toBottomOf="@id/tv_cost"
                app:layout_constraintStart_toEndOf="@id/iv_pin"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tv_description"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_secondary_gray"
                android:textSize="15.5sp"
                android:breakStrategy="simple"
                app:layout_constraintTop_toBottomOf="@id/iv_pin"
                app:layout_constraintStart_toStartOf="@id/tv_name"
                app:layout_constraintEnd_toEndOf="@id/tv_name"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_checkin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tab_gray"
                android:layout_marginStart="15dp"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="3dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tv_description"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/cl_checkout">

                <ImageView
                    android:id="@+id/iv_checkin_clock"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="10dp"
                    android:src="@drawable/ic_clock_orange_32"
                    app:tint="@color/text_secondary_gray"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintWidth_percent="0.12"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/tv_checkin_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/info_checkin"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary_gray"
                    app:layout_constraintTop_toBottomOf="@id/iv_checkin_clock"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/tv_checkin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="10:00"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/tv_checkin_label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_checkout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tab_gray"
                android:layout_marginEnd="15dp"
                android:layout_marginTop="15dp"
                android:layout_marginStart="3dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tv_description"
                app:layout_constraintStart_toEndOf="@id/cl_checkin"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/iv_checkout_clock"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="10dp"
                    android:src="@drawable/ic_clock_orange_32"
                    app:tint="@color/text_secondary_gray"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintWidth_percent="0.12"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/tv_checkout_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/info_checkout"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary_gray"
                    app:layout_constraintTop_toBottomOf="@id/iv_checkout_clock"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/tv_checkout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="10:00"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/tv_checkout_label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>


            </androidx.constraintlayout.widget.ConstraintLayout>
            
            <TextView
                android:id="@+id/tv_addition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/info_signature"
                android:textColor="@color/text_secondary_gray"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/tv_description"
                app:layout_constraintStart_toStartOf="@id/tv_name"/>
            
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_addition"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="15dp"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/tv_addition"
                app:layout_constraintStart_toStartOf="@id/tv_addition"
                app:layout_constraintEnd_toEndOf="parent"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_option"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/rv_addition"
                app:layout_constraintStart_toStartOf="@id/rv_addition"
                app:layout_constraintEnd_toEndOf="@id/rv_addition"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_map"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginBottom="15dp"
                android:layout_marginTop="15dp"
                android:text="@string/info_map"
                android:textAllCaps="false"
                android:textColor="@color/text_secondary_gray"
                android:textSize="15sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingVertical="0dp"
                android:elevation="10dp"
                android:translationZ="2.2dp"
                app:cornerRadius="5dp"
                app:strokeColor="@color/state_complete_gray"
                app:strokeWidth="1dp"
                app:backgroundTint="@color/white"
                app:icon="@drawable/ic_pin_gray_24"
                app:iconTint="@color/text_secondary_gray"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:layout_constraintTop_toBottomOf="@id/rv_option"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/tv_name"
                app:layout_constraintEnd_toEndOf="@id/tv_name"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>