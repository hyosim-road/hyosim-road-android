<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_record"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_white_stroke"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/iv_image"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="10dp"
            android:scaleType="centerCrop"
            android:src="@drawable/image_trip"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintTop_toTopOf="@id/tv_trip_name"
            app:layout_constraintBottom_toBottomOf="@id/rv_keywords"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tv_trip_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/main_trip_title_mock"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginStart="5dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_image"/>

        <ImageView
            android:id="@+id/iv_calendar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="7dp"
            android:src="@drawable/ic_calendar_red_24"
            app:tint="@color/text_secondary_gray"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.04"
            app:layout_constraintTop_toBottomOf="@id/tv_trip_name"
            app:layout_constraintStart_toStartOf="@id/tv_trip_name"/>

        <TextView
            android:id="@+id/tv_during"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:textColor="@color/text_secondary_gray"
            app:layout_constraintTop_toTopOf="@id/iv_calendar"
            app:layout_constraintBottom_toBottomOf="@id/iv_calendar"
            app:layout_constraintStart_toEndOf="@id/iv_calendar"/>

        <ImageView
            android:id="@+id/iv_pin"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="7dp"
            android:src="@drawable/ic_pin_gray_24"
            app:tint="@color/text_secondary_gray"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.04"
            app:layout_constraintTop_toBottomOf="@id/iv_calendar"
            app:layout_constraintStart_toStartOf="@id/tv_trip_name"/>

        <TextView
            android:id="@+id/tv_trip_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:textColor="@color/text_secondary_gray"
            app:layout_constraintTop_toTopOf="@id/iv_pin"
            app:layout_constraintBottom_toBottomOf="@id/iv_pin"
            app:layout_constraintStart_toEndOf="@id/iv_pin"/>

        <ImageView
            android:id="@+id/iv_camera"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="7dp"
            android:src="@drawable/ic_camera_gray_24"
            app:tint="@color/text_secondary_gray"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.04"
            app:layout_constraintTop_toBottomOf="@id/iv_pin"
            app:layout_constraintStart_toStartOf="@id/tv_trip_name"/>

        <TextView
            android:id="@+id/tv_photo_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:textColor="@color/text_secondary_gray"
            app:layout_constraintTop_toTopOf="@id/iv_camera"
            app:layout_constraintBottom_toBottomOf="@id/iv_camera"
            app:layout_constraintStart_toEndOf="@id/iv_camera"/>

        <ImageView
            android:id="@+id/iv_answer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="7dp"
            android:layout_marginStart="18dp"
            android:src="@drawable/ic_message_red_24"
            app:tint="@color/text_secondary_gray"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.04"
            app:layout_constraintTop_toBottomOf="@id/iv_pin"
            app:layout_constraintStart_toEndOf="@id/tv_photo_count"/>

        <TextView
            android:id="@+id/tv_answer_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:textColor="@color/text_secondary_gray"
            app:layout_constraintTop_toTopOf="@id/iv_answer"
            app:layout_constraintBottom_toBottomOf="@id/iv_answer"
            app:layout_constraintStart_toEndOf="@id/iv_answer"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_keywords"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="7dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/iv_camera"
            app:layout_constraintStart_toStartOf="@id/tv_trip_name"
            app:layout_constraintEnd_toEndOf="parent"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_album"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:layout_marginBottom="20dp"
            android:layout_marginEnd="5dp"
            android:layout_marginTop="20dp"
            android:text="@string/trip_record_see_album"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary_gray"
            android:textSize="15sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingVertical="0dp"
            android:elevation="10dp"
            android:translationZ="2.2dp"
            app:cornerRadius="5dp"
            app:strokeColor="@color/state_complete_gray"
            app:strokeWidth="1dp"
            app:backgroundTint="@color/white"
            app:icon="@drawable/ic_album_white_24"
            app:iconTint="@color/text_secondary_gray"
            app:iconGravity="textStart"
            app:layout_constraintTop_toBottomOf="@id/rv_keywords"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_detail"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_detail"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_white_stroke"
            android:text="@string/trip_record_detail"
            android:textColor="@color/text_secondary_gray"
            android:layout_marginEnd="10dp"
            app:layout_constraintDimensionRatio="1:0.36"
            app:layout_constraintTop_toTopOf="@id/btn_album"
            app:layout_constraintStart_toEndOf="@id/btn_album"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>