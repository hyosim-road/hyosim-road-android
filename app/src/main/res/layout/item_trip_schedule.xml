<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="5dp"
    android:paddingBottom="5dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageView
        android:id="@+id/iv_bg_gray"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/complete_preview_bg_gray"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ImageView
        android:id="@+id/iv_icon"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_percent="0.09"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/iv_bg_gray"/>

    <TextView
        android:id="@+id/tv_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1"
        android:textColor="@color/text_secondary_gray"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/iv_icon"
        app:layout_constraintStart_toStartOf="@id/iv_icon"
        app:layout_constraintEnd_toEndOf="@id/iv_icon"
        app:layout_constraintBottom_toBottomOf="@id/iv_icon"/>

    <TextView
        android:id="@+id/tv_place"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:text="@string/main_trip_location_mock"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="@id/iv_icon"
        app:layout_constraintStart_toEndOf="@id/iv_icon"
        app:layout_constraintBottom_toTopOf="@id/iv_time"/>

    <TextView
        android:id="@+id/tv_keyword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/keyword_history"
        android:background="@drawable/bg_place_outline"
        android:layout_marginStart="10dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        app:layout_constraintTop_toTopOf="@id/tv_place"
        app:layout_constraintBottom_toBottomOf="@id/tv_place"
        app:layout_constraintStart_toEndOf="@id/tv_place"/>

    <TextView
        android:id="@+id/tv_current"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_current"
        android:textColor="@color/white"
        android:background="@drawable/bg_current_orange"
        android:layout_marginStart="6dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/tv_place"
        app:layout_constraintBottom_toBottomOf="@id/tv_place"
        app:layout_constraintStart_toEndOf="@id/tv_keyword"/>

    <TextView
        android:id="@+id/tv_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="15dp"
        android:gravity="start"
        android:textColor="@color/text_secondary_gray"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_place"
        app:layout_constraintStart_toStartOf="@id/tv_place"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/iv_time"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/ic_time_gray_24"
        android:layout_marginTop="5dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_percent="0.04"
        app:layout_constraintTop_toBottomOf="@id/tv_place"
        app:layout_constraintStart_toStartOf="@id/tv_place"
        app:layout_constraintBottom_toBottomOf="@id/iv_icon"/>

    <TextView
        android:id="@+id/tv_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="09:00 ~ 10:00"
        android:textColor="@color/text_secondary_gray"
        android:textSize="13sp"
        android:layout_marginStart="6dp"
        app:layout_constraintTop_toTopOf="@id/iv_time"
        app:layout_constraintBottom_toBottomOf="@id/iv_time"
        app:layout_constraintStart_toEndOf="@id/iv_time"/>

</androidx.constraintlayout.widget.ConstraintLayout>